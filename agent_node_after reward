    def reset_reward_system(self):
        """Réinitialise le système de récompenses pour un nouvel épisode"""
        # Conserver quelques informations d'apprentissage
        minerals_before = self.reward_system.minerals_collected
        
        # Réinitialiser
        self.reward_system.reset_episode()
        self.visited_positions.clear()
        self.steps_without_mineral = 0
        
        # Log
        self.get_logger().info(f'🔄 Reward system reset. Total minerals so far: {minerals_before}')
    ###


    def is_episode_done(self):
        # Terminer si trop d'actions sans récompense positive
        if self.steps > 200 and self.episode_reward < 5.0:
            return True
        
        # Terminer si assez de minéraux collectés
        if self.minerals_collected >= 3:  # Réduit
            return True
        
        # Terminer après un nombre maximum de steps
        if self.steps >= 300:  # Réduit
            return True
        
        return False
        
