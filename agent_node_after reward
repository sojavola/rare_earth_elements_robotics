def print_reward_report(self):
    """Affiche un rapport détaillé du système de récompenses"""
    stats = self.reward_system.get_statistics()
    
    self.get_logger().info(
        f'📊 REAL Reward System Report - Robot {self.robot_id}:\n'
        f'   Minéraux collectés: {stats["minerals_collected"]}\n'
        f'   Récompense totale: {stats["total_reward"]:.1f}\n'
        f'   Positions visitées: {stats["visited_positions"]}\n'
        f'   Couverture: {stats["coverage_percentage"]:.1f}%\n'
        f'   Steps sans minéral: {stats["steps_without_mineral"]}'
    )
    
    # Afficher un rapport détaillé tous les 10 épisodes
    if self.episodes % 10 == 0:
        self.reward_system.print_detailed_report()
 ###

        
def main(argv=None):
    rclpy.init(args=argv)
    argv = argv if argv is not None else sys.argv
    robot_id = parse_robot_id_from_argv(argv)
    node = None

    try:
        node = REEExplorationAgent(robot_id=robot_id)
        rclpy.spin(node)
    except KeyboardInterrupt:
        if node is not None:
            node.get_logger().info('🛑 KeyboardInterrupt: saving model and logs, shutting down...')
            try:
                # save final model
                if getattr(node.agent, 'use_shared_model', False):
                    node.agent.save_model(os.path.join("models", "shared", "final_shared_model.pth"))
                else:
                    node.agent.save_model(os.path.join(node.save_dir, "final_model.pth"))
                # save logs on shutdown
                node.save_training_logs()
            except Exception as e:
                node.get_logger().warn(f'⚠️ saving on shutdown failed: {e}')
    except Exception as e:
        if node is not None:
            node.get_logger().error(f'❌ Fatal error in agent node: {e}')
        import traceback
        traceback.print_exc()
    finally:
        if node is not None:
            node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
