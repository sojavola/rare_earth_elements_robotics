import rclpy
from rclpy.node import Node
import numpy as np
import threading
import time
import random
import sys
import os
import json
from datetime import datetime

from std_msgs.msg import Float32MultiArray, String, Int32, Float32
from geometry_msgs.msg import Pose2D, Twist
from nav_msgs.msg import OccupancyGrid

from .advanced_dqn_agent import RobustDQNAgent  # Import du vrai DQN

import sys
print(f"=== DÉBUT ROBOT {sys.argv[1] if len(sys.argv) > 1 else 0} ===")
print(f"Arguments complets: {sys.argv}")


class REEExplorationAgent(Node):
    def __init__(self, robot_id=0):
        super().__init__(f'ree_exploration_agent_{robot_id}')
        
        self.robot_id = robot_id
        print(f"🎯 ROBOT ID DÉFINI: {self.robot_id}")
        
        # ✅ AJOUTEZ ce debug
        print(f"📝 Arguments ROS: {sys.argv}")
        print(f"📝 Robot ID from constructor: {robot_id}")
        print(f"📝 Self.robot_id: {self.robot_id}")
        
        self.agent_name = f'robot_{self.robot_id}'  # ✅ Utilisez self.robot_id
        # Configuration

        self.map_width = 100
        self.map_height = 100
        self.num_actions = 8  # 8 directions
        self.state_shape = (self.map_height, self.map_width, 4)  # mineral channels
        
        # État actuel
        self.mineral_map = np.zeros((self.map_height, self.map_width, 4))
        self.obstacle_map = np.zeros((self.map_height, self.map_width))
        self.science_targets = np.zeros((self.map_height, self.map_width))
        self.current_position = self.get_initial_position()
        self.last_position = self.current_position
        
        # ✅ VÉRIFIEZ l'ID avant de créer l'agent
        print(f"🔍 Vérification avant création agent: robot_id={self.robot_id}")
        # Vrai Agent DQN
        self.agent = RobustDQNAgent(
            state_shape=self.state_shape,
            num_actions=self.num_actions,
            robot_id=self.robot_id,  # ✅ TRÈS IMPORTANT: passez self.robot_id
            learning_rate=0.00025,   # ✅ Comme dans le papier
            gamma=0.99,
            epsilon=1.0,
            epsilon_min=0.01,
            epsilon_decay=0.998,
            memory_size=1000,  # Réduit pour debug
            batch_size=32,      # Réduit pour debug
            target_update=1000,  # Réduit pour debug
            load_latest_model=True,
            use_shared_model=True 
        )
        
        # initialiser les variables pour le callbacks 
        self.global_step_count = 0
        self.latest_loss = 0.0

        # Après la création de l'agent
        self.dqn_update_pub = self.create_publisher(
            Float32MultiArray, 
            '/agent/dqn_update', 
            10
        )
        self.step_completed_pub = self.create_publisher(
            Int32, 
            '/agent/step_completed', 
            10
        )
        self.epsilon_pub = self.create_publisher(
            Float32, 
            '/agent/epsilon', 
            10
        )

        # Subscribers pour synchronisation
        self.global_step_sub = self.create_subscription(
            Int32,
            '/global/step_count',
            self.global_step_callback,
            10
        )

        self.model_update_sub = self.create_subscription(
            String,
            '/global/model_update',
            self.model_update_callback,
            10
        )

        self.global_epsilon_sub = self.create_subscription(
            Float32,
            '/global/epsilon',
            self.global_epsilon_callback,
            10
        )

        def global_step_callback(self, msg):
            """Met à jour le compteur global depuis le coordinateur"""
            self.global_step_count = msg.data
            if hasattr(self.agent, 'shared_manager'):
                self.agent.shared_manager.global_step_count = msg.data

        def model_update_callback(self, msg):
            """Reçoit les mises à jour du modèle"""
            try:
                data = json.loads(msg.data)
                self.get_logger().info(f'🔄 Model sync: Version {data.get("model_version", 0)}')
            except:
                pass

        def global_epsilon_callback(self, msg):
            """Synchronise epsilon avec les autres robots"""
            self.agent.epsilon = msg.data

        
        def publish_dqn_update(self, loss=0.0):
        # Dans make_decision(), après chaque entraînement :
            if hasattr(self, 'dqn_update_pub'):
                # Publier les stats DQN
                update_msg = Float32MultiArray()
                update_msg.data = [
                    float(self.robot_id),
                    float(loss if 'loss' in locals() else 0.0),
                    float(self.agent.epsilon),
                    float(len(self.agent.memory)),
                    float(self.global_step_count)
                ]
                self.dqn_update_pub.publish(update_msg)
                
                # Publier la complétion du step
                step_msg = Int32()
                step_msg.data = self.global_step_count
                self.step_completed_pub.publish(step_msg)
                
                # Publier epsilon
                epsilon_msg = Float32()
                epsilon_msg.data = float(self.agent.epsilon)
                self.epsilon_pub.publish(epsilon_msg)



        # Statistiques d'apprentissage
        self.verify_model_sharing()
        self.steps = 0
        self.episodes = 0
        self.total_reward = 0
        self.episode_reward = 0
        self.minerals_collected = 0
        self.unique_minerals_found = set()
        
        # Mémoire d'épisode
        self.episode_memory = []
        
        # Verrou pour accès thread-safe
        self.lock = threading.Lock()
        
        # Publishers
        self.position_pub = self.create_publisher(Pose2D, f'/{self.agent_name}/position', 10)
        self.velocity_pub = self.create_publisher(Twist, f'/{self.agent_name}/cmd_vel', 10)
        self.cleaning_pub = self.create_publisher(Float32MultiArray, f'/{self.agent_name}/cleaning_action', 10)
        self.status_pub = self.create_publisher(String, f'/{self.agent_name}/status', 10)
        self.discovery_pub = self.create_publisher(Float32MultiArray, '/shared_discoveries', 10)
        
        # Subscribers
        self.mineral_sub = self.create_subscription(
            Float32MultiArray, '/mineral_map', self.mineral_callback, 10)
        self.obstacle_sub = self.create_subscription(
            OccupancyGrid, '/obstacle_map', self.obstacle_callback, 10)
        self.science_sub = self.create_subscription(
            Float32MultiArray, '/science_targets', self.science_callback, 10)
        
        # Timers
        self.decision_timer = self.create_timer(1.0, self.make_decision)  # 1 Hz
        self.training_timer = self.create_timer(0.5, self.train_agent)  # Entraînement plus fréquent
        self.status_timer = self.create_timer(5.0, self.publish_status)
        self.position_timer = self.create_timer(0.5, self.publish_position)
        
        # Répertoire de sauvegarde
        self.save_dir = f"models/robot_{robot_id}"
        os.makedirs(self.save_dir, exist_ok=True)
        
        self.get_logger().info(f'🚀 DQN Agent Node {robot_id} initialized')
        self.get_logger().info(f'📍 Initial position: {self.current_position}')
        self.get_logger().info(f'🧠 DQN: {self.agent.num_actions} actions, ε={self.agent.epsilon:.3f}')
    
   
    def verify_model_sharing(self):
        """Vérifie que le modèle est bien partagé entre les robots"""
        print(f"🔍 Robot {self.robot_id} - Vérification modèle partagé...")
        
        if hasattr(self.agent, 'shared_manager'):
            manager = self.agent.shared_manager
            
            # Vérifier l'ID mémoire du modèle
            policy_id = id(self.agent.policy_net)
            target_id = id(self.agent.target_net)
            
            print(f"   📊 Policy net ID: {policy_id}")
            print(f"   📊 Target net ID: {target_id}")
            print(f"   🤖 Robots enregistrés: {manager.robot_ids}")
            
            # Si c'est le premier robot, enregistrer la référence
            if not hasattr(manager, '_shared_model_id'):
                manager._shared_model_id = policy_id
                print(f"   ✅ Référence établie par Robot {self.robot_id}")
            else:
                if policy_id == manager._shared_model_id:
                    print(f"   ✅ MODÈLE PARTAGÉ CONFIRMÉ!")
                else:
                    print(f"   ❌ ERREUR: Modèle non partagé (IDs différents)")
        else:
            print(f"   ⚠️  Pas de shared_manager détecté")


    def get_initial_position(self):
        """Retourne une position initiale valide"""
        return (random.randint(20, self.map_width - 20), 
                random.randint(20, self.map_height - 20))
    
    def mineral_callback(self, msg):
        """Callback pour la carte minérale"""
        with self.lock:
            if len(msg.data) == self.map_height * self.map_width * 4:
                self.mineral_map = np.array(msg.data).reshape(
                    self.map_height, self.map_width, 4
                )
    
    def obstacle_callback(self, msg):
        """Callback pour la carte d'obstacles"""
        with self.lock:
            if len(msg.data) == self.map_height * self.map_width:
                self.obstacle_map = np.array(msg.data).reshape(
                    self.map_height, self.map_width
                )
    
    def science_callback(self, msg):
        """Callback pour les cibles scientifiques"""
        with self.lock:
            if len(msg.data) == self.map_height * self.map_width:
                self.science_targets = np.array(msg.data).reshape(
                    self.map_height, self.map_width
                )
    
    def get_current_state(self):
        """Retourne l'état actuel pour le DQN"""
        with self.lock:
            # Normaliser les données
            normalized_mineral_map = self.mineral_map.copy()
            normalized_position = (
                self.current_position[0] / self.map_width,
                self.current_position[1] / self.map_height
            )
            
            return (normalized_mineral_map, normalized_position)
    
    def make_decision(self):
        """Prend une décision de mouvement avec le DQN"""
        if np.max(self.mineral_map) == 0:
            return  # Attendre les données de la carte
        
        state = self.get_current_state()
        action = self.agent.choose_action(state)
        
        # Exécuter l'action
        reward, done = self.execute_action(action)
        
        # Nouvel état après l'action
        next_state = self.get_current_state()
        
        # Stocker l'expérience
        self.agent.store_experience(state, action, reward, next_state, done)
        self.episode_memory.append((state, action, reward, next_state, done))
        
        # Mettre à jour les statistiques
        self.episode_reward += reward
        self.total_reward += reward
        self.steps += 1
        
        # Gérer la fin d'épisode
        if done or self.steps >= 500:  # Épisode de 500 steps max
            self.end_episode()
        
        if self.steps % 10 == 0:  # Log moins fréquent
            self.get_logger().debug(f'🎯 Step {self.steps}: Action {action}, Reward {reward:.2f}, ε={self.agent.epsilon:.3f}')
    
    def execute_action(self, action):
        """Exécute une action et retourne la récompense et si terminé"""
        x, y = self.current_position
        new_x, new_y = x, y
        
        # Mapping des actions aux directions
        direction_vectors = [
            (0, 1),    # 0: Nord
            (0, -1),   # 1: Sud  
            (-1, 0),   # 2: Ouest
            (1, 0),    # 3: Est
            (-1, 1),   # 4: Nord-Ouest
            (1, 1),    # 5: Nord-Est
            (-1, -1),  # 6: Sud-Ouest
            (1, -1)    # 7: Sud-Est
        ]
        
        dx, dy = direction_vectors[action]
        new_x = max(0, min(self.map_width - 1, x + dx))
        new_y = max(0, min(self.map_height - 1, y + dy))
        
        # Vérifier les collisions
        if self.is_valid_position(new_x, new_y):
            self.last_position = self.current_position
            self.current_position = (new_x, new_y)
            reward = self.calculate_reward(new_x, new_y)
            done = self.is_episode_done()
            
            # Publier l'action de nettoyage
            self.publish_cleaning_action(new_x, new_y)
            
            # Publier les découvertes importantes
            if reward > 5.0:
                self.publish_discovery(new_x, new_y)
        else:
            reward = -2.0  # Pénalité de collision
            done = False
        
        return reward, done
    
    def is_valid_position(self, x, y):
        """Vérifie si la position est valide (pas d'obstacle)"""
        return (0 <= x < self.map_width and 
                0 <= y < self.map_height and
                self.obstacle_map[y, x] == 0)
    
    def calculate_reward(self, x, y):
        """Calcule la récompense basée sur la valeur scientifique"""
        reward = 0.0
        
        if 0 <= y < self.map_height and 0 <= x < self.map_width:
            # Récompense pour les minéraux
            mineral_concentrations = self.mineral_map[y, x, :]
            max_concentration = np.max(mineral_concentrations)
            
            if max_concentration > 0.1:
                # Récompense proportionnelle à la concentration
                mineral_reward = max_concentration * 10.0
                reward += mineral_reward
                
                # Bonus pour les concentrations élevées
                if max_concentration > 0.7:
                    reward += 5.0
                    self.minerals_collected += 1
                    
                    # Identifier le type de minéral
                    mineral_type = np.argmax(mineral_concentrations)
                    self.unique_minerals_found.add(mineral_type)
                    
                    self.get_logger().info(f'💎 High-value mineral found! Type: {mineral_type}, Concentration: {max_concentration:.2f}')
            
            # Récompense pour l'exploration
            if self.science_targets[y, x] > 0.3:
                exploration_reward = self.science_targets[y, x] * 3.0
                reward += exploration_reward
            
            # Récompense pour le mouvement
            reward += 0.1
            
            # Pénalité pour les mouvements répétitifs
            if self.current_position == self.last_position:
                reward -= 0.5
        
        return reward
    
    def is_episode_done(self):
        """Détermine si l'épisode est terminé"""
        # Terminer si le robot est bloqué ou a accompli beaucoup
        if self.steps > 50 and self.episode_reward < 1.0:
            return True
        
        # Terminer après un certain nombre de minéraux collectés
        if self.minerals_collected >= 5:
            return True
            
        return False
    
    def train_agent(self):
        """Entraîne l'agent DQN"""
        if len(self.agent.memory) >= self.agent.batch_size:
            loss = self.agent.train()
            
            if loss > 0 and self.steps % 50 == 0:
                self.get_logger().info(f'📚 Training - Loss: {loss:.4f}, Memory: {len(self.agent.memory)}')
    
    def end_episode(self):
        """Termine l'épisode courant et prépare le suivant"""
        self.episodes += 1
        
        # ✅ METTRE À JOUR LE COMPTEUR GLOBAL
        if hasattr(self.agent, 'shared_manager'):
            self.agent.shared_manager.global_episode_count += 1
        
        # ✅ SAUVEGARDE POUR MODÈLE PARTAGÉ
        if hasattr(self.agent, 'use_shared_model') and self.agent.use_shared_model:
            if self.episodes % 5 == 0:
                # Sauvegarder le modèle partagé
                model_path = f"models/shared/shared_model_episode_{self.episodes}.pth"
                self.agent.save_model(model_path)
                
                # Sauvegarder aussi comme latest
                latest_path = "models/shared/latest_shared_model.pth"
                self.agent.save_model(latest_path)
                
                print(f"💾 Robot {self.robot_id}: Modèle PARTAGÉ sauvegardé (épisode {self.episodes})")
        else:
            # Ancienne méthode (modèles individuels)
            if self.episodes % 5 == 0:
                model_path = f"models/robot_{self.robot_id}/model_episode_{self.episodes}.pth"
                self.agent.save_model(model_path)
                
                latest_path = f"models/robot_{self.robot_id}/latest_model.pth"
                self.agent.save_model(latest_path)
        
        # Log des statistiques
        self.get_logger().info(f'📊 Episode {self.episodes} completed: '
                            f'Steps: {self.steps}, '
                            f'Reward: {self.episode_reward:.1f}, '
                            f'Minerals: {self.minerals_collected}, '
                            f'ε: {self.agent.epsilon:.3f}')
        
        # Réinitialiser
        self.current_position = self.get_initial_position()
        self.last_position = self.current_position
        self.episode_reward = 0
        self.steps = 0
        self.minerals_collected = 0
        self.episode_memory = []
        
        self.get_logger().info(f'🔄 Starting new episode at {self.current_position}')

    
    def publish_position(self):
        """Publie la position actuelle"""
        msg = Pose2D()
        msg.x = float(self.current_position[0])
        msg.y = float(self.current_position[1])
        msg.theta = 0.0
        
        self.position_pub.publish(msg)
    
    def publish_cleaning_action(self, x, y):
        """Publie une action de nettoyage"""
        msg = Float32MultiArray()
        msg.data = [float(x), float(y)]
        self.cleaning_pub.publish(msg)
    
    def publish_discovery(self, x, y):
        """Publie une découverte importante"""
        msg = Float32MultiArray()
        mineral_data = self.mineral_map[y, x, :].tolist()
        msg.data = [float(self.robot_id), float(x), float(y)] + mineral_data
        self.discovery_pub.publish(msg)
    
    def publish_velocity(self, linear_x=0.1, angular_z=0.0):
        """Publie une commande de vitesse (pour simulation)"""
        msg = Twist()
        msg.linear.x = linear_x
        msg.angular.z = angular_z
        self.velocity_pub.publish(msg)
    
    def publish_status(self):
        """Publie le statut de l'agent"""
        status_msg = String()
        status_text = (f"Robot {self.robot_id} - "
                      f"Episode: {self.episodes}, "
                      f"Steps: {self.steps}, "
                      f"Reward: {self.episode_reward:.1f}, "
                      f"Minerals: {self.minerals_collected}, "
                      f"ε: {self.agent.epsilon:.3f}")
        
        status_msg.data = status_text
        self.status_pub.publish(status_msg)
        
        # Log moins fréquent pour éviter le spam
        if self.steps % 20 == 0:
            self.get_logger().info(f'📈 {status_text}')

def main(args=None):
    rclpy.init(args=args)
    
    # ✅ CORRECTION CRITIQUE: Récupérer l'ID correctement
    robot_id = 0
    
    print(f"🎯 Arguments reçus: {sys.argv}")
    print(f"🎯 Nombre d'arguments: {len(sys.argv)}")
    
    # Méthode 1: Depuis les arguments ROS2
    if len(sys.argv) > 1:
        arg = sys.argv[1]
        print(f"🎯 Premier argument: '{arg}'")
        
        # Essayer plusieurs méthodes pour extraire l'ID
        try:
            # Essayer directement la conversion
            robot_id = int(arg)
            print(f"🎯 ID extrait par conversion directe: {robot_id}")
        except ValueError:
            # Essayer d'extraire un nombre de la chaîne
            import re
            numbers = re.findall(r'\d+', arg)
            if numbers:
                robot_id = int(numbers[0])
                print(f"🎯 ID extrait par regex: {robot_id}")
            else:
                print(f"⚠️  Pas de nombre trouvé dans '{arg}', utilisation par défaut: 0")
                robot_id = 0
    
    # Méthode 2: Variable d'environnement (alternative)
    env_id = os.getenv('ROBOT_ID')
    if env_id is not None:
        try:
            robot_id = int(env_id)
            print(f"🎯 ID depuis variable d'environnement: {robot_id}")
        except:
            pass
    
    print(f"🚀 Lancement du Robot {robot_id}")
    
    # ✅ CRÉATION DU NODE AVEC L'ID FORCÉ
    node = REEExplorationAgent(robot_id=robot_id)
    
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        node.get_logger().info('🛑 Shutting down DQN agent...')
        
        # Sauvegarder le modèle partagé
        if hasattr(node.agent, 'use_shared_model') and node.agent.use_shared_model:
            model_path = "models/shared/final_shared_model.pth"
        else:
            model_path = f"models/robot_{robot_id}/final_model.pth"
        
        node.agent.save_model(model_path)
        
    except Exception as e:
        node.get_logger().error(f'❌ Error in DQN agent: {e}')
        import traceback
        traceback.print_exc()
    finally:
        node.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()